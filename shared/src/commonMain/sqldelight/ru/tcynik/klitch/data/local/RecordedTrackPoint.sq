CREATE TABLE recorded_track_point (
    track_id  TEXT    NOT NULL,
    timestamp INTEGER NOT NULL,
    lat       REAL    NOT NULL,
    lon       REAL    NOT NULL,
    accuracy  REAL    NOT NULL DEFAULT 0.0,
    PRIMARY KEY (track_id, timestamp)
);

insertPoint:
INSERT OR IGNORE INTO recorded_track_point(track_id, timestamp, lat, lon, accuracy)
VALUES (:trackId, :timestamp, :lat, :lon, :accuracy);

selectByTrackId:
SELECT * FROM recorded_track_point WHERE track_id = :trackId ORDER BY timestamp ASC;

selectAll:
SELECT * FROM recorded_track_point ORDER BY track_id, timestamp ASC;

deleteByTrackId:
DELETE FROM recorded_track_point WHERE track_id = :trackId;

deleteBeforeTimestamp:
DELETE FROM recorded_track_point WHERE track_id = :trackId AND timestamp < :timestampMs;

deleteAfterTimestamp:
DELETE FROM recorded_track_point WHERE track_id = :trackId AND timestamp > :timestampMs;
